rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "academy@codezero.ge" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }
    function isValidUser(data) {
      return (!('uid' in data) || data.uid is string) && 
             (!('email' in data) || data.email is string) &&
             (!('role' in data) || data.role == null || data.role in ['shipper', 'driver', 'admin', 'client', 'owner', 'renter']) &&
             (!('subscriptionStatus' in data) || data.subscriptionStatus in ['active', 'inactive']) &&
             (!('displayName' in data) || data.displayName == null || isValidString(data.displayName, 200)) &&
             (!('phone' in data) || data.phone == null || isValidString(data.phone, 50)) &&
             (!('photoURL' in data) || data.photoURL == null || data.photoURL is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }
    function isValidPost(data) {
      return (!('userId' in data) || data.userId is string) && 
             (!('type' in data) || data.type in ['cargo', 'route']) &&
             (!('origin' in data) || data.origin is map) && 
             (!('destination' in data) || data.destination is map) &&
             (!('status' in data) || data.status in ['active', 'completed']) &&
             (!('description' in data) || isValidString(data.description, 5000)) &&
             (!('contactPhone' in data) || isValidString(data.contactPhone, 50)) &&
             (!('price' in data) || data.price is number || data.price is string) &&
             (!('images' in data) || data.images is list);
    }
    function isValidMessage(data) {
      return (!('chatId' in data) || data.chatId is string) && 
             (!('senderId' in data) || data.senderId is string) && 
             (!('text' in data) || isValidString(data.text, 5000));
    }
    function isValidEquipment(data) {
      return (!('title' in data) || isValidString(data.title, 500)) && 
             (!('price' in data) || data.price is string || data.price is number) && 
             (!('ownerId' in data) || data.ownerId is string) &&
             (!('description' in data) || isValidString(data.description, 5000)) &&
             (!('images' in data) || data.images is list) &&
             (!('rating' in data) || data.rating is number) &&
             (!('reviewCount' in data) || data.reviewCount is number);
    }
    function isValidReview(data) {
      return data.equipmentId is string && data.userId is string && 
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             isValidString(data.comment, 2000);
    }
    function isValidBooking(data) {
      return data.equipmentId is string && data.userId is string && 
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /posts/{postId} {
      allow read: if true; // Posts are public
      allow create: if isAuthenticated() && 
                      isValidPost(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.type in ['cargo', 'route'] &&
                      request.resource.data.origin is map &&
                      request.resource.data.destination is map;
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid && isValidPost(request.resource.data)) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /equipment/{equipmentId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                       isValidEquipment(request.resource.data) && 
                       request.resource.data.ownerId == request.auth.uid &&
                       request.resource.data.ownerId is string;
      allow update: if (isAuthenticated() && resource.data.ownerId == request.auth.uid && isValidEquipment(request.resource.data)) || 
                       isAdmin() || 
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
      allow delete: if (isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.ownerId || isAdmin());
      allow create: if isAuthenticated() && isValidBooking(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && isValidMessage(request.resource.data);
      }
    }
  }
}
