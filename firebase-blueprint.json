{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["shipper", "driver", "admin"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Post": {
      "title": "Post",
      "description": "Cargo request or Driver route",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["cargo", "route"] },
        "origin": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "destination": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "contactPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "origin", "destination", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat room between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Individual message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Equipment categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Heavy equipment listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "Equipment booking request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "equipmentId": { "type": "string" },
        "equipmentTitle": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "ownerId": { "type": "string" },
        "bookingDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "price": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Cargo and Route posts"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat rooms"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Equipment categories"
    },
    "/equipment/{equipmentId}": {
      "schema": "Equipment",
      "description": "Heavy equipment listings"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Equipment bookings"
    }
  }
}
